# ─── Supabase (https://supabase.com/dashboard → Project Settings → API) ───────
# Required for authentication and data persistence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Podcast Index API (https://podcastindex.org/signup) ──────────────────────
# Required for real podcast data. Without these, the app falls back to mock data.
PODCAST_INDEX_API_KEY=your_api_key_here
PODCAST_INDEX_API_SECRET=your_api_secret_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
