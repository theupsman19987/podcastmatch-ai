# ─── Supabase (https://supabase.com/dashboard → Project Settings → API) ───────
# Required for authentication and data persistence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Stripe (https://dashboard.stripe.com/apikeys) ────────────────────────────
# Required for subscription billing. Without these, billing UI shows a message.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs — create products in Stripe Dashboard then paste IDs here
STRIPE_PRICE_CREATOR_PRO=price_...
STRIPE_PRICE_VISIBILITY_PRO=price_...

# ─── Podcast Index API (https://podcastindex.org/signup) ──────────────────────
# Required for real podcast data. Without these, the app falls back to mock data.
PODCAST_INDEX_API_KEY=your_api_key_here
PODCAST_INDEX_API_SECRET=your_api_secret_here

# ─── SEO ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# ─── Resend (https://resend.com/api-keys) ─────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM=hello@podcastmatchai.com
RESEND_ADMIN_EMAIL=your@gmail.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://podmatch.ai
